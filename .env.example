APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# 'sync' so the demo's OTP/verification emails are delivered immediately (and the
# code is written straight to storage/logs/laravel.log with MAIL_MAILER=log).
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Laravel Rebel ----
# Server-side secret ("pepper") used for keyed-HMAC hashing of identifiers, IPs and
# OTPs. REQUIRED. Generate a random 64-char hex value, e.g.:
#   php -r "echo bin2hex(random_bytes(32));"
REBEL_PEPPER_V1=
REBEL_PEPPER_CURRENT=1

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---- Audit dispatch (laravel-rebel-core) ----
# 'sync' (default) writes inline; 'queue' dispatches a job per event (Horizon-ready).
REBEL_AUDIT_MODE=sync
# REBEL_AUDIT_QUEUE_CONNECTION=
# REBEL_AUDIT_QUEUE=

# ---- Geo (country) capture (laravel-rebel-core) ----
# Country is read from this request header (Cloudflare sets CF-IPCountry in prod).
REBEL_GEO_ENABLED=true
REBEL_GEO_COUNTRY_HEADER=CF-IPCountry
# Demo-only shim: injected when no CF-IPCountry header is present (localhost has no Cloudflare).
DEMO_COUNTRY=IT

# ---- Twilio delivery webhook (laravel-rebel-channel-twilio) ----
# Set Twilio's StatusCallback to https://<host>/rebel/twilio/status to capture delivery + cost.
REBEL_TWILIO_WEBHOOK=true
REBEL_TWILIO_WEBHOOK_VALIDATE=true
